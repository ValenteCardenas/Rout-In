<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Required for dispatching heads-up push notifications on Android 13+ (API 33+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Required to trigger haptic vibration for the anti-blindness intervention (SPEC03) -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- Required for triggering precise native alarms (SPEC11) -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.RoutIn">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.RoutIn">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
            NotificationActionReceiver — captures interactive notification button taps.
            android:exported="false" restricts delivery to intents from this app only,
            satisfying Android 12+ PendingIntent mutability requirements (SPEC03, SPEC04).
        -->
        <receiver
            android:name=".receiver.NotificationActionReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.uam.routin.ACTION_MOVE_HABIT_630" />
                <action android:name="com.uam.routin.ACTION_RELOCATE_HABIT_730" />
                <action android:name="com.uam.routin.ACTION_ROUTINE_ALARM" />
            </intent-filter>
        </receiver>

    </application>

</manifest>